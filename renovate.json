{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/Rome",
  "labels": ["dependencies"],
  "minimumReleaseAge": "6 hours",
  "prConcurrentLimit": 5,
  "rangeStrategy": "pin",
  "pip_requirements": {
    "managerFilePatterns": ["/requirements\\.txt$/"]
  },
  "packageRules": [
    {
      "description": "Group all non-major Python dependency updates",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python dependencies (non-major)"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group Docker base image / compose updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker images"
    },
    {
      "description": "Auto-merge low-risk minor and patch updates after CI passes",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  }
}
